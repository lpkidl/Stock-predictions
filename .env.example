# Stock Forecaster Configuration
# Copy this file to .env and fill in your values

# Application Settings
DEBUG=False
APP_NAME="Stock Forecaster"

# Reddit Settings
REDDIT_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
REDDIT_REQUEST_TIMEOUT=10

# X/Twitter Twikit Settings (Optional - only if you want X/Twitter data)
# Get these by creating a burner account on X/Twitter
X_USERNAME=your_x_username_here
X_PASSWORD=your_x_password_here
X_EMAIL=your_x_email_here
X_SESSION_CACHE_PATH=.twikit_session

# Stock and Processing Settings
STOCK_TICKERS="AAPL,NVDA,TSLA,GOOGL,MSFT"
SENTIMENT_MODEL="ProsusAI/finbert"
SENTIMENT_BATCH_SIZE=16

# Data Retention
HISTORICAL_DAYS=365
FORECAST_DAYS=5

# Rate Limiting (seconds between requests)
REDDIT_DELAY=2.0
X_DELAY=3.0
YFINANCE_DELAY=1.0

# ML Model Settings
# XGBoost parameters: n_estimators, max_depth, learning_rate, random_state, n_jobs
TRAIN_TEST_SPLIT_RATIO=0.8

# Streamlit UI Settings
STREAMLIT_PAGE_TITLE="Stock Forecaster - AI-Powered Sentiment Analysis"
STREAMLIT_PAGE_ICON="📈"
