# Stock Forecaster Configuration
# Copy this file to .env and fill in your values

# Application Settings
DEBUG=False
APP_NAME="Stock Forecaster"

# Stock tickers to analyse (comma-separated, no spaces)
STOCK_TICKERS="AAPL,NVDA,TSLA,GOOGL,MSFT"

# ── Reddit ───────────────────────────────────────────────────────────────────
# Reddit data works out of the box with NO credentials required.
# Appending .json to public Reddit URLs returns raw data for free.
# The pipeline fetches posts + top comments from the subreddits below and
# runs them through FinBERT for sentiment features.
#
# Optional: set PRAW credentials to use the official Reddit API instead
# (higher rate limits, more reliable).  Leave blank to use the free .json path.
PRAW_CLIENT_ID=
PRAW_CLIENT_SECRET=
PRAW_USER_AGENT="StockForecaster/1.0 by u/your_reddit_username"

# Subreddits to scrape (comma-separated, ordered by priority)
# REDDIT_SUBREDDITS=["wallstreetbets","stocks"]

# Fetch top comment bodies per post for richer sentiment signal (true/false)
# REDDIT_FETCH_COMMENTS=true
# REDDIT_COMMENT_LIMIT=10

# HTTP scraper settings
REDDIT_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
REDDIT_REQUEST_TIMEOUT=10
REDDIT_DELAY=2.0

# ── X / Twitter (Optional) ──────────────────────────────────────────────────
# Requires a free X account.  The twikit library authenticates with username +
# password + email; a session cookie is cached locally after the first login.
X_USERNAME=
X_PASSWORD=
X_EMAIL=
X_SESSION_CACHE_PATH=.twikit_session
X_DELAY=3.0

# ── LLM News Sentiment (Optional but recommended) ────────────────────────────
# NewsAPI: free at https://newsapi.org/register  (100 req/day)
# Groq:    free at https://console.groq.com      (14,400 req/day, Llama 3.3 70B)
# When both keys are set, the pipeline fetches recent news for each ticker and
# uses Llama 3.3 to score sentiment, risk, and catalysts as ML features.
NEWSAPI_KEY=
GROQ_API_KEY=
NEWS_LOOKBACK_DAYS=7
NEWS_MAX_ARTICLES=10

# ── Alpha Vantage (Optional) ─────────────────────────────────────────────────
# Free key at https://www.alphavantage.co/support/#api-key (500 calls/day)
# Enables intraday OHLCV + news sentiment features.
ALPHA_VANTAGE_API_KEY=

# ── NLP Settings ─────────────────────────────────────────────────────────────
SENTIMENT_MODEL="ProsusAI/finbert"
SENTIMENT_BATCH_SIZE=16

# ── ML Settings ──────────────────────────────────────────────────────────────
HISTORICAL_PERIOD=2y
FORECAST_HORIZONS=[1,3,5,10]

# ── Rate Limiting ────────────────────────────────────────────────────────────
YFINANCE_DELAY=1.0

# ── Trade Simulation (ExecutionEngine) ──────────────────────────────────────
ACCOUNT_SIZE=100000.0
POSITION_RISK_PCT=0.01
ATR_MULTIPLIER_SL=2.0
ATR_MULTIPLIER_TP=3.0
MIN_TRADE_CONFIDENCE=0.50

# ── Streamlit UI ─────────────────────────────────────────────────────────────
STREAMLIT_PAGE_TITLE="Stock Forecaster - AI-Powered Sentiment Analysis"
STREAMLIT_PAGE_ICON="📈"
